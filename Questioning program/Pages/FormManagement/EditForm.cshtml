@page "{formId}"
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Questioning_Data_Repositories.StaticValue
@model Questioning_program.Pages.FormManagement.EditFormModel
@{
    ViewData["Title"] = "ویرایش اطلاعات فرم";
    var editForm = Model.EditForm;
    var categoryData = ViewData["CategoryData"];
}

<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>ویرایش فرم امتحان جدید</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-left">
                        <li class="breadcrumb-item"><a href="/">خانه</a></li>
                        <li class="breadcrumb-item"><a href="/FormManagement/IndexForm">لیست فرم‌ها</a></li>
                        <li class="breadcrumb-item active">ویرایش فرم</li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <form method="post" role="form">
                <div class="row">
                    <!-- بخش اطلاعات فرم -->
                    <div class="col-md-12">
                        <div class="card card-warning">
                            <div class="card-header">
                                <h3 class="card-title">اطلاعات فرم</h3>
                            </div>
                            <div class="card-body">
                                <input type="hidden" asp-for="EditForm.FormId" />
                                <div class="form-group">
                                    <label asp-for="EditForm.FormTitle">@Html.DisplayNameFor(m => editForm.FormTitle)</label>
                                    <input type="text" class="form-control" asp-for="EditForm.FormTitle" placeholder="عنوان فرم را وارد کنید">

                                    <small>
                                        <span asp-validation-for="EditForm.FormTitle" class="text text-danger"></span>
                                    </small>
                                </div>

                                <div class="form-group">
                                    <label asp-for="EditForm.FormDescription">@Html.DisplayNameFor(m => editForm.FormDescription)</label>
                                    <textarea class="form-control" asp-for="EditForm.FormDescription" placeholder="توضیحات فرم"></textarea>

                                    <small>
                                        <span asp-validation-for="EditForm.FormDescription" class="text text-danger"></span>
                                    </small>
                                </div>

                                <div class="form-group">
                                    <label asp-for="EditForm.FormDescription">@Html.DisplayNameFor(m => editForm.AccessCode)</label>
                                    <input class="form-control" asp-for="EditForm.AccessCode" placeholder="کد شناسایی را وارد کنید" />

                                    <small>
                                        <span asp-validation-for="EditForm.AccessCode" class="text text-danger"></span>
                                    </small>
                                </div>

                                <div class="form-group form-select">
                                    @if (categoryData != null)
                                    {
                                        <select class="form-control" asp-for="EditForm.FkCategoryId" asp-items="@(SelectList)categoryData">
                                            <option value="" selected="selected" hidden="hidden">لطفا دسته بندی خود را انتخاب کنید</option>
                                        </select>
                                    }
                                    else
                                    {
                                        <select class="form-control">
                                            <option value="">لیست انتخابی یافت نشد</option>
                                        </select>
                                    }

                                    <small>
                                        <span class="text text-danger" asp-validation-for="EditForm.FkCategoryId"></span>
                                    </small>
                                </div>

                                <div class="form-group form-check">
                                    <input asp-for="EditForm.IsActive" type="checkbox" class="form-check-input">
                                    <label class="form-check-label" asp-for="EditForm.IsActive">@Html.DisplayNameFor(m => editForm.IsActive)</label>

                                    <small>
                                        <span asp-validation-for="EditForm.IsActive" class="text text-danger"></span>
                                    </small>
                                </div>

                                <div class="form-group form-check">
                                    <input asp-for="EditForm.IsPublic" type="checkbox" class="form-check-input">
                                    <label class="form-check-label" asp-for="EditForm.IsPublic">@Html.DisplayNameFor(m => editForm.IsPublic)</label>

                                    <small>
                                        <span asp-validation-for="EditForm.IsPublic" class="text text-danger"></span>
                                    </small>
                                </div>

                                <div class="row">
                                    <div class="form-group col-md-3">
                                        <input data-jdp data-jdp-only-time type="text" class="form-control" placeholder="ساعت شروع آزمون" asp-for="EditForm.StartExamTime" />

                                        <small>
                                            <span asp-validation-for="EditForm.StartExamTime" class="text text-danger"></span>
                                        </small>
                                    </div>

                                    <div class="form-group col-md-3">
                                        <input data-jdp data-jdp-only-time type="text" class="form-control" placeholder="ساعت پایان آزمون" asp-for="EditForm.EndExamTime" />

                                        <small>
                                            <span asp-validation-for="EditForm.EndExamTime" class="text text-danger"></span>
                                        </small>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="form-group col-md-3">
                                        <input data-jdp data-jdp-only-date type="text" class="form-control" placeholder="تاریخ شروع آزمون" asp-for="EditForm.StartExamDate" />

                                        <small>
                                            <span asp-validation-for="EditForm.StartExamDate" class="text text-danger"></span>
                                        </small>
                                    </div>

                                    <div class="form-group col-md-3">
                                        <input data-jdp data-jdp-only-date type="text" class="form-control" placeholder="تاریخ پایان آزمون" asp-for="EditForm.EndExamDate" />
                                        <small>
                                            <span asp-validation-for="EditForm.EndExamDate" class="text text-danger"></span>
                                        </small>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer">
                                <button type="submit" class="btn btn-primary">✔️ ثبت نهایی فرم آزمون</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- سوالات موجود -->
                    <div class="col-md-4">
                        <div class="card card-info">
                            <div class="card-header">
                                <h3 class="card-title">📚 سوالات فرم</h3>
                            </div>
                            <div class="card-body">
                                <ul class="list-group" id="questionList">
                                    @foreach (var q in editForm.Questions)
                                    {
                                        var answerData = q.Answers.FirstOrDefault();
                                        if (answerData == null) { continue; }

                                        // اگر سوال داخل SelectedQuestions هست، نمایش نده
                                        if (editForm.SelectedQuestions != null && editForm.SelectedQuestions.Any(s => s.QuestionId == q.QuestionId))
                                        {
                                            continue;
                                        }

                                        <li class="list-group-item" draggable="true" data-question="true" data-question-id="@q.QuestionId">
                                            <button type="button" class="btn btn-link btn-sm text-danger delete-btn float-left" style="font-size: 1.2rem;">×</button>
                                            <div class="ml-4">
                                                <h6>@q.QuestionText</h6>

                                                @switch (answerData.AnswerTypes)
                                                {
                                                    case AnswerTypeEnumTypes.Anatomical:
                                                        <span class="badge badge-primary">تشریحی</span>
                                                        <textarea class="form-control mt-2" readonly>@answerData.AnswerText</textarea>
                                                        break;

                                                    case AnswerTypeEnumTypes.Test:
                                                        <span class="badge badge-success">تستی</span>
                                                        <ul class="list-group mt-2">
                                                            <li class="list-group-item">
                                                                <input type="radio" disabled @(answerData.TestCorrectOption == answerData.TestOptionOne ? "checked" : "") />
                                                                @answerData.TestOptionOne
                                                            </li>
                                                            <li class="list-group-item">
                                                                <input type="radio" disabled @(answerData.TestCorrectOption == answerData.TestOptionTwo ? "checked" : "") />
                                                                @answerData.TestOptionTwo
                                                            </li>
                                                            <li class="list-group-item">
                                                                <input type="radio" disabled @(answerData.TestCorrectOption == answerData.TestOptionThree ? "checked" : "") />
                                                                @answerData.TestOptionThree
                                                            </li>
                                                            <li class="list-group-item">
                                                                <input type="radio" disabled @(answerData.TestCorrectOption == answerData.TestOptionFour ? "checked" : "") />
                                                                @answerData.TestOptionFour
                                                            </li>
                                                        </ul>
                                                        break;

                                                    case AnswerTypeEnumTypes.TrueOrFalse:
                                                        <span class="badge badge-warning">درست/غلط</span>
                                                        <div class="form-check mt-2">
                                                            <input type="radio" disabled @(answerData.TruOrFalseAnswer == true ? "checked" : "") />
                                                            <label>صحیح</label>
                                                        </div>
                                                        <div class="form-check">
                                                            <input type="radio" disabled @(answerData.TruOrFalseAnswer == false ? "checked" : "") />
                                                            <label>غلط</label>
                                                        </div>
                                                        break;
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- طراحی برگه آزمون -->
                    <div class="col-md-8">
                        <div class="card card-success">
                            <div class="card-header">
                                <h3 class="card-title">📝 طراحی برگه آزمون</h3>
                            </div>
                            <div class="card-body">
                                <ul class="list-group" id="examDesign">
                                    @if (editForm.SelectedQuestions != null && editForm.SelectedQuestions.Any())
                                    {
                                        foreach (var selected in editForm.SelectedQuestions.OrderBy(s => s.Order))
                                        {
                                            var question = editForm.Questions.FirstOrDefault(q => q.QuestionId == selected.QuestionId);
                                            if (question != null)
                                            {
                                                var answerData = question.Answers.FirstOrDefault();
                                                <li class="list-group-item" draggable="true" data-question="true" data-question-id="@question.QuestionId">
                                                    <button type="button" class="btn btn-link btn-sm text-danger delete-btn float-left" style="font-size: 1.2rem;">×</button>
                                                    <div class="ml-4">
                                                        <h6>@question.QuestionText</h6>
                                                        @* مشابه نمایش جواب ها *@
                                                        @switch (answerData?.AnswerTypes)
                                                        {
                                                            case AnswerTypeEnumTypes.Anatomical:
                                                                <span class="badge badge-primary">تشریحی</span>
                                                                <textarea class="form-control mt-2" readonly>@answerData.AnswerText</textarea>
                                                                break;
                                                            case AnswerTypeEnumTypes.Test:
                                                                <span class="badge badge-success">تستی</span>
                                                                <ul class="list-group mt-2">
                                                                    <li class="list-group-item">
                                                                        <input type="radio" disabled @(answerData.TestCorrectOption == answerData.TestOptionOne ? "checked" : "") />
                                                                        @answerData.TestOptionOne
                                                                    </li>
                                                                    <li class="list-group-item">
                                                                        <input type="radio" disabled @(answerData.TestCorrectOption == answerData.TestOptionTwo ? "checked" : "") />
                                                                        @answerData.TestOptionTwo
                                                                    </li>
                                                                    <li class="list-group-item">
                                                                        <input type="radio" disabled @(answerData.TestCorrectOption == answerData.TestOptionThree ? "checked" : "") />
                                                                        @answerData.TestOptionThree
                                                                    </li>
                                                                    <li class="list-group-item">
                                                                        <input type="radio" disabled @(answerData.TestCorrectOption == answerData.TestOptionFour ? "checked" : "") />
                                                                        @answerData.TestOptionFour
                                                                    </li>
                                                                </ul>
                                                                break;
                                                            case AnswerTypeEnumTypes.TrueOrFalse:
                                                                <span class="badge badge-warning">درست/غلط</span>
                                                                <div class="form-check mt-2">
                                                                    <input type="radio" disabled @(answerData.TruOrFalseAnswer == true ? "checked" : "") />
                                                                    <label>صحیح</label>
                                                                </div>
                                                                <div class="form-check">
                                                                    <input type="radio" disabled @(answerData.TruOrFalseAnswer == false ? "checked" : "") />
                                                                    <label>غلط</label>
                                                                </div>
                                                                break;
                                                        }
                                                    </div>
                                                </li>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <li class="list-group-item text-center text-muted">سوالی اضافه نشده است</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

            </form>
        </div>
    </section>
</div>

@section JavaScriptsSection
{
    <script src="/WebsiteScripts/DragDropEditQuestion.js"></script>
    <script>
        jalaliDatepicker.startWatch({ time: true });
    </script>
}
