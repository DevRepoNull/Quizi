@page
@model Questioning_program.Pages.CategoryManagement.AddCategoryModel
@{
    ViewData["Title"] = "افزودن دسته بندی";
    var categoryFirst = Model.Category;
}

<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>صفحه اضافه کردن دسته بندی ها</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-left">
                        <li class="breadcrumb-item">
                            <a href="/">خانه</a>
                        </li>
                        <li class="breadcrumb-item">
                            <a asp-page="/CategoryManagement/IndexCategory">لیست دسته بندی ها</a>
                        </li>
                        <li class="breadcrumb-item active">افزودن دسته بندی ها</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <form method="post" role="form">
                <div class="row">
                    <!-- right col -->
                    <div class="col-md-12">
                        <!-- general form elements -->
                        <div class="card card-primary">
                            <div class="card-header">
                                <h3 class="card-title">اطلاعات دسته بندی</h3>
                            </div>
                            <!-- /.card-header -->
                            <!-- form start -->
                            <div class="card-body">
                                <div class="form-group">
                                    <label asp-for="Category.CategoryName">@Html.DisplayNameFor(m => categoryFirst.CategoryName)</label>
                                    <input type="text" class="form-control" asp-for="Category.CategoryName" placeholder="لطفا دسته بندی را وارد کنید" />
                                </div>
                                <small>
                                   <span class="text text-danger" asp-validation-for="Category.CategoryName"></span>
                                </small>

                            </div>
                            <!-- /.card-body -->

                            <div class="card-footer">
                                <button type="submit" class="btn btn-primary">ثبت اطلاعات</button>
                            </div>
                        </div>
                        <!-- /.card -->
                    </div>
                    <!--/ right col -->
                </div>
                <!-- /.row -->
            </form>
        </div><!-- /.container-fluid -->
    </section>
    <!-- /.content -->
</div>

