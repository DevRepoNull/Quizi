@page
@using System.Security.Claims
@using Questioning_Data_Repositories.ViewModel.AdminPanelVms
@model Questioning_program.Pages.EnteringTheExam.ExamListIndexModel
@{
    ViewData["Title"] = "لیست آزمون";
    var examDataList = Model.ExamList.FirstOrDefault() ?? new ExamDataViewModel();
}

<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>لیست آزمون</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-left">
                        <li class="breadcrumb-item"><a href="/">خانه</a></li>
                        <li class="breadcrumb-item active">لیست آزمون ها</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <!-- /.row -->
            <div class="row">
                <div class="col-12">
                    @if (Model.ExamList != null && Model.ExamList.Any())
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">لیست امتحانات</h3>

                                <div class="card-tools">
                                    <div class="input-group input-group-sm" style="width: 150px;">
                                        <input type="text" name="table_search" class="form-control float-right" placeholder="جستجو">

                                        <div class="input-group-append">
                                            <button type="submit" class="btn btn-default"><i class="fa fa-search"></i></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- /.card-header -->
                            <div class="card-body table-responsive p-0">
                                <table class="table table-hover">
                                    <tr>
                                        <th>@Html.DisplayNameFor(m => examDataList.FormTitle)</th>
                                        <th>@Html.DisplayNameFor(m => examDataList.StartExamDate)</th>
                                        <th>@Html.DisplayNameFor(m => examDataList.EndExamTime)</th>
                                        <th>@Html.DisplayNameFor(m => examDataList.StartExamDate)</th>
                                        <th>@Html.DisplayNameFor(m => examDataList.EndExamTime)</th>
                                        <th>دستورات</th>
                                    </tr>
                                    @foreach (var item in Model.ExamList)
                                    {
                                        <tr>
                                            <td>@item.FormTitle</td>
                                            <td>@item.StartExamTime</td>
                                            <td>@item.EndExamTime</td>
                                            <td>@item.StartExamDate</td>
                                            <td>@item.EndExamDate</td>
                                            <td>
                                                <a class="btn btn-sm btn-info" asp-page="/EnteringTheExam/UserExam" asp-route-examId="@item.FormId">ورود به امتحان</a> | 
                                                <a class="btn btn-sm btn-warning" asp-page="/EnteringTheExam/ReportUserExam" asp-route-examId="@item.FormId" asp-route-userId="@User.FindFirst(ClaimTypes.NameIdentifier)?.Value">گزارش امتخان</a>
                                            </td>
                                        </tr>
                                    }
                                </table>
                            </div>
                            <!-- /.card-body -->
                            <!-- /.card-body -->
                            <div class="card-footer clearfix">
                                <ul class="pagination pagination-sm m-0 float-right">
                                    <li class="page-item"><a class="page-link" href="#">«</a></li>
                                    <li class="page-item"><a class="page-link" href="#">۱</a></li>
                                    <li class="page-item"><a class="page-link" href="#">۲</a></li>
                                    <li class="page-item"><a class="page-link" href="#">۳</a></li>
                                    <li class="page-item"><a class="page-link" href="#">»</a></li>
                                </ul>
                            </div>
                        </div>
                        <!-- /.card -->
                    }
                    else
                    {
                        <div class="alert alert-danger">
                            <p class="text text-center">در حال حاضر آزمونی برای ورود به امتحان وجود ندارد</p>
                        </div>
                    }
                </div>
            </div>
            <!-- /.row -->

        </div><!-- /.container-fluid -->
    </section>
    <!-- /.content -->
</div>