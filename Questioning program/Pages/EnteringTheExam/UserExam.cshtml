@page "{examId}"
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Questioning_Data_Repositories.StaticValue
@using Questioning_Data_Repositories.ViewModel.AdminPanelVms
@model Questioning_program.Pages.EnteringTheExam.UserExamModel
@{
    Layout = null;
    var showExamData = Model.ExamData ?? new();
}

<!DOCTYPE html>
<html lang="fa">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>نمایش @showExamData.FormTitle</title>
    <link rel="stylesheet" href="/WebsiteCss/ExamStyleCss.css"/>
</head>
<body>
<div class="exam-container">
    <div class="exam-header">
        <h2>@showExamData.FormTitle</h2>
    </div>

    <form method="post">
        @for (int i = 0; i < showExamData.Questions.Count; i++)
        {
            var item = Model.ExamData.Questions[i];
            var answerData = item.Answers.FirstOrDefault();
            if (answerData == null)
            {
                continue;
            }

            <div class="question">
                <h4>@item.QuestionText</h4>

                <input type="hidden" asp-for="UserAnswers[@i].FormId" />
                <input type="hidden" asp-for="UserAnswers[@i].QuestionId" />
                <input type="hidden" asp-for="UserAnswers[@i].AnswerId" />
                <input type="hidden" asp-for="UserAnswers[@i].FkUserId" />

                @switch (item.QuestionType)
                {
                    case AnswerTypeEnumTypes.Anatomical:
                        <textarea asp-for="UserAnswers[@i].DescriptiveAnswerText"
                                  placeholder="لطفا پاسخ تشریحی وارد کنید ..."></textarea>
                        break;

                    case AnswerTypeEnumTypes.Test:
                        <div class="options">
                            <input type="radio" asp-for="UserAnswers[@i].SelectedOption" value="OptionOne" id="q@i_o1"/>
                            <label for="q@i_o1">@answerData.OptionOne</label>

                            <input type="radio" asp-for="UserAnswers[@i].SelectedOption" value="OptionTwo" id="q@i_o2"/>
                            <label for="q@i_o2">@answerData.OptionTwo</label>

                            <input type="radio" asp-for="UserAnswers[@i].SelectedOption" value="OptionThree"
                                   id="q@i_o3"/>
                            <label for="q@i_o3">@answerData.OptionThree</label>

                            <input type="radio" asp-for="UserAnswers[@i].SelectedOption" value="OptionFour"
                                   id="q@i_o4"/>
                            <label for="q@i_o4">@answerData.OptionFour</label>
                        </div>
                        break;

                    case AnswerTypeEnumTypes.TrueOrFalse:
                        <div class="options">
                            <input type="radio" asp-for="UserAnswers[@i].SelectedTrueOrFalse" value="true" id="q@i_t"/>
                            <label for="q@i_t">صحیح</label>

                            <input type="radio" asp-for="UserAnswers[@i].SelectedTrueOrFalse" value="false" id="q@i_f"/>
                            <label for="q@i_f">غلط</label>
                        </div>
                        break;
                }
            </div>
        }

        <button type="submit" class="submit-btn">ثبت پاسخ‌ها</button>
    </form>
</div>
</body>
</html>
