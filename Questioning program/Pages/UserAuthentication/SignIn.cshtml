@page "/SignIn"
@model Questioning_program.Pages.UserAuthentication.SignInModel
@{
    Layout = null;
    ViewData["Title"] = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>ثبت نام کاربر</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="/AdminTemplate/dist/css/adminlte.min.css">
    <!-- iCheck -->
    <link rel="stylesheet" href="/AdminTemplate/plugins/iCheck/square/blue.css">
    <!-- Google Font: Source Sans Pro -->
    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700" rel="stylesheet">

    <!-- bootstrap rtl -->
    <link rel="stylesheet" href="/AdminTemplate/dist/css/bootstrap-rtl.min.css">
    <!-- template rtl version -->
    <link rel="stylesheet" href="/AdminTemplate/dist/css/custom-style.css">
</head>
<body class="hold-transition register-page">
    <div class="register-box">
        <div class="register-logo">
            <b>ثبت نام در سایت</b>
        </div>

        <div class="card">
            <div class="card-body register-card-body">
                <p class="login-box-msg">ثبت نام کاربر جدید</p>

                <form method="post">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" asp-for="SignInViewModel.FirstName" placeholder="نام">
                        <div class="input-group-append">
                            <span class="fa fa-user input-group-text"></span>
                        </div>
                    </div>
                    <small>
                        <span asp-validation-for="SignInViewModel.FirstName" class="text text-danger"></span>
                    </small>

                    <div class="input-group mb-3">
                        <input type="text" class="form-control" asp-for="SignInViewModel.LastName" placeholder="نام خانوادگی">
                        <div class="input-group-append">
                            <span class="fa fa-user input-group-text"></span>
                        </div>
                    </div>
                    <small>
                        <span asp-validation-for="SignInViewModel.LastName" class="text text-danger"></span>
                    </small>

                    <div class="input-group mb-3">
                        <input type="email" class="form-control" asp-for="SignInViewModel.Email" placeholder="ایمیل">
                        <div class="input-group-append">
                            <span class="fa fa-envelope input-group-text"></span>
                        </div>
                    </div>
                    <small>
                        <span asp-validation-for="SignInViewModel.Email" class="text text-danger"></span>
                    </small>

                    <div class="input-group mb-3">
                        <input type="text" class="form-control" asp-for="SignInViewModel.UserName" placeholder="نام کاربری">
                        <div class="input-group-append">
                            <span class="fa fa-user-md input-group-text"></span>
                        </div>
                    </div>
                    <small>
                        <span asp-validation-for="SignInViewModel.UserName" class="text text-danger"></span>
                    </small>

                    <div class="input-group mb-3">
                        <input type="number" class="form-control" asp-for="SignInViewModel.PhoneNumber" placeholder="شماره تماس">
                        <div class="input-group-append">
                            <span class="fa fa-mobile input-group-text"></span>
                        </div>
                    </div>
                    <small>
                        <span asp-validation-for="SignInViewModel.PhoneNumber" class="text text-danger"></span>
                    </small>
                    
                    <div class="input-group mb-3">
                        <input type="number" class="form-control" asp-for="SignInViewModel.NationalCode" placeholder="کد ملی">
                        <div class="input-group-append">
                            <span class="fa fa-male input-group-text"></span>
                        </div>
                    </div>
                    <small>
                        <span asp-validation-for="SignInViewModel.NationalCode" class="text text-danger"></span>
                    </small>

                    <div class="input-group mb-3">
                        <input type="password" class="form-control" asp-for="SignInViewModel.Password" placeholder="رمز عبور">
                        <div class="input-group-append">
                            <span class="fa fa-lock input-group-text"></span>
                        </div>
                    </div>
                    <small>
                        <span asp-validation-for="SignInViewModel.Password" class="text text-danger"></span>
                    </small>

                    <div class="input-group mb-3">
                        <input type="password" class="form-control" asp-for="SignInViewModel.RePassword" placeholder="تکرار رمز عبور">
                        <div class="input-group-append">
                            <span class="fa fa-lock input-group-text"></span>
                        </div>
                    </div>
                    <small>
                        <span asp-validation-for="SignInViewModel.RePassword" class="text text-danger"></span>
                    </small>

                    <div class="row">
                        @* <div class="col-8">
                            <div class="checkbox icheck">
                                <label>
                                    <input type="checkbox"> با <a href="#">شرایط</a> موافق هستم
                                </label>
                            </div>
                        </div> *@
                        <!-- /.col -->
                        <div class="col-4">
                            <button type="submit" class="btn btn-primary btn-block btn-flat">ثبت نام</button>
                        </div>
                        <!-- /.col -->
                    </div>
                </form>

                <a href="/Login" class="text-center">من قبلا ثبت نام کرده ام</a>
            </div>
            <!-- /.form-box -->
        </div><!-- /.card -->
    </div>
    <!-- /.register-box -->
    <!-- jQuery -->
    <script src="/AdminTemplate/plugins/jquery/jquery.min.js"></script>
    <!-- Bootstrap 4 -->
    <script src="/AdminTemplate/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- iCheck -->
    <script src="/AdminTemplate/plugins/iCheck/icheck.min.js"></script>
    <script>
        $(function () {
          $('input').iCheck({
            checkboxClass: 'icheckbox_square-blue',
            radioClass   : 'iradio_square-blue',
            increaseArea : '20%' // optional
          })
        })
    </script>
</body>
</html>